@page "{listingId:int}"
@model SwoopMarketplaceProjectFrontend.Pages.Reports.CreateModel

<div style="max-width:600px;margin:40px auto;padding:20px;background:#fff;border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,0.08)">

    <h2 style="margin-bottom:10px">Hirdetés jelentése</h2>
    <p style="color:#6b7280;margin-bottom:20px">
        Kérlek írd le, miért jelenteted ezt a hirdetést.
    </p>

    <form method="post">
        <input type="hidden" asp-for="Report.ListingId" />

        <div style="margin-bottom:16px">
            <label style="font-weight:600">Leírás</label>
            <textarea asp-for="Report.Description"
                      style="width:100%;height:120px;padding:10px;border-radius:8px;border:1px solid #e5e7eb"
                      required></textarea>
        </div>

        <div style="display:flex;gap:10px">
            <button type="submit"
                    style="flex:1;padding:10px;background:#ef4444;color:#fff;border:none;border-radius:8px;font-weight:700">
                Jelentés küldése
            </button>

            <a asp-page="/Listings/Details"
               asp-route-azon="@Model.Report.ListingId"
               style="flex:1;padding:10px;background:#eef2ff;color:#4c51bf;border-radius:8px;text-align:center;text-decoration:none;font-weight:700">
                Mégse
            </a>
        </div>
    </form>

    @if (Model.Success)
    {
        <div style="margin-top:16px;padding:10px;background:#ecfdf5;color:#065f46;border-radius:8px">
            ✅ Jelentés sikeresen elküldve!
        </div>
    }

</div>
@page
@model IndexModel
@{
    // keep a compact hero with CTA linking to the create page
}
<section style="max-width:1200px;margin:18px auto;padding:18px;border-radius:12px;background:linear-gradient(180deg,#ffffff,#fbfdff);box-shadow:0 8px 24px rgba(2,6,23,0.04);display:flex;align-items:center;gap:18px;flex-wrap:wrap">
    <div style="flex:1;min-width:260px">
        <h1 style="margin:0;font-size:28px;font-weight:800;color:#111;font-family:Segoe UI,Roboto,Arial,sans-serif">Fedezd fel a Swoop piacteret</h1>
        <p style="margin:8px 0 0;color:#6b7280">Keress praktikus ajánlatokat — elektronikát, bútorokat, kertészeti eszközöket és még sok mást. Szabadon feladhatod a saját hirdetésedet.</p>
        <div style="margin-top:14px;display:flex;gap:10px;flex-wrap:wrap">
            <a asp-page="/Listings/Create" style="background:linear-gradient(90deg,#6c5ce7,#5a4de6);color:#fff;padding:12px 16px;border-radius:10px;text-decoration:none;font-weight:800">Hirdetés feladása</a>
            <a asp-page="/Listings/Index" style="background:#eef2ff;color:#4c51bf;padding:12px 16px;border-radius:10px;text-decoration:none;font-weight:700">Böngészés</a>
        </div>
    </div>

    <div style="width:320px;min-width:220px">
        <div style="background:#fff;padding:12px;border-radius:10px;box-shadow:0 6px 18px rgba(2,6,23,0.04)">
            <div style="font-weight:700;color:#111">Gyors kategóriák</div>
            <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:8px">
                <a asp-page="/Listings/Index" asp-route-categoryId="1" style="padding:8px 10px;background:#f7f9fc;border-radius:8px;text-decoration:none;color:#374151;font-weight:700">Electronics</a>
                <a asp-page="/Listings/Index" asp-route-categoryId="2" style="padding:8px 10px;background:#f7f9fc;border-radius:8px;text-decoration:none;color:#374151;font-weight:700">Gardening</a>
                <a asp-page="/Listings/Index" asp-route-categoryId="3" style="padding:8px 10px;background:#f7f9fc;border-radius:8px;text-decoration:none;color:#374151;font-weight:700">Furniture</a>
                <a asp-page="/Listings/Index" asp-route-categoryId="4" style="padding:8px 10px;background:#f7f9fc;border-radius:8px;text-decoration:none;color:#374151;font-weight:700">Fashion</a>
                <a asp-page="/Listings/Index" asp-route-categoryId="5" style="padding:8px 10px;background:#f7f9fc;border-radius:8px;text-decoration:none;color:#374151;font-weight:700">Vehicles</a>
            </div>
        </div>
    </div>
</section>

<h2 style="margin-top:22px;font-family:Segoe UI,Roboto,Arial,sans-serif;color:#222">Friss hirdetések</h2>

<div class="listing-grid" style="margin-top:12px">
    @foreach (var l in Model.Featured)
    {
        <partial name="/Shared/_ListingCard" model="l" />
    }
</div>
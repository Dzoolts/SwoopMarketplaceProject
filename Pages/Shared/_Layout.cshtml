@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Swoop Marketplace</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        /* small local styles for the floating CTA so no external CSS changes required */
        .fab {
            position:fixed;
            right:20px;
            bottom:24px;
            background:linear-gradient(90deg,#6c5ce7,#5a4de6);
            color:#fff;
            padding:14px 18px;
            border-radius:999px;
            box-shadow:0 14px 36px rgba(92,71,229,0.20);
            font-weight:800;
            text-decoration:none;
            z-index:1200;
            display:flex;
            align-items:center;
            gap:10px;
        }
        .fab small { font-weight:600; font-size:12px; opacity:0.95; }
    </style>
</head>
<body>
    <header class="site-header">
        <div class="container header-inner">
            <a class="brand" asp-page="/Index">Swoop</a>

            <form class="search-form" method="get" asp-page="/Listings/Index">
                <input name="q" type="text" placeholder="Search listings, e.g. 'iPhone'..." />
                <button type="submit">Search</button>
            </form>

            <nav class="nav">
                <a asp-page="/Listings/Create" class="btn">Hirdetés feladása</a>
            </nav>
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">© Swoop Marketplace</div>
    </footer>

    <!-- Floating CTA for quick access -->
    <a class="fab" asp-page="/Listings/Create" title="Hirdetés feladása">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <div>
            <div style="line-height:1">Hirdetés feladása</div>
            <small>Add new listing</small>
        </div>
    </a>
</body>
</html>